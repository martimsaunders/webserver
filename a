#include <cerrno>
#include <climits>
#include <cstdlib>
#include <sstream>
#include <stdexcept>

static std::runtime_error parseError(Token const &tok, std::string const &msg) {
    std::ostringstream oss;
    oss << "Parse error at " << tok.line << ":" << tok.col << ": " << msg;
    return std::runtime_error(oss.str());
}

static bool isValueToken(Token const &t) {
    return (t.type == Identifier || t.type == String || t.type == Number);
}

static unsigned long parseUL(Token const &tok, std::string const &what) {
    if (tok.type != Number)
        throw parseError(tok, "expected number for " + what);

    errno = 0;
    char *end = 0;
    unsigned long v = std::strtoul(tok.value.c_str(), &end, 10);
    if (errno != 0 || end == tok.value.c_str() || *end != '\0')
        throw parseError(tok, "invalid number for " + what + ": '" + tok.value + "'");
    return v;
}

struct Parser {
    std::vector<Token> const &toks;
    size_t pos;

    Parser(std::vector<Token> const &t) : toks(t), pos(0) {}

    Token const &peek(size_t off = 0) const {
        if (pos + off >= toks.size())
            return toks[toks.size() - 1];
        return toks[pos + off];
    }

    bool at(TokenType tt) const { return peek().type == tt; }

    bool atWord(std::string const &w) const {
        return (peek().type == Identifier && peek().value == w);
    }

    Token const &advance() {
        Token const &cur = peek();
        if (!at(End)) pos++;
        return cur;
    }

    void expect(TokenType tt, std::string const &msg) {
        if (!at(tt)) throw parseError(peek(), msg);
        advance();
    }

    void expectWord(std::string const &w) {
        if (!atWord(w)) throw parseError(peek(), "expected '" + w + "'");
        advance();
    }

    std::string expectValue(std::string const &ctx) {
        if (!isValueToken(peek()))
            throw parseError(peek(), "expected value for " + ctx);
        return advance().value;
    }

    void skipUnknownStatement() {
        // assumes current token is the statement name (Identifier/String/Number)
        Token const start = advance();

        // Eat args until we hit ';' or '{'
        while (!at(End) && !at(Semicolon) && !at(LBrace))
            advance();

        if (at(Semicolon)) {
            advance();
            return;
        }

        if (at(LBrace)) {
            advance();
            int depth = 1;
            while (!at(End) && depth > 0) {
                if (at(LBrace)) depth++;
                else if (at(RBrace)) depth--;
                advance();
            }
            if (depth != 0) throw parseError(start, "unterminated block");
            return;
        }

        throw parseError(start, "unexpected end while skipping");
    }
};

static ServerConfig defaultServer() {
    ServerConfig s;
    s.port = -1;
    s.client_max_body_size = 0;
    s.host = "0.0.0.0";
    s.root = "";
    s.index = "";
    return s;
}

static LocationConfig defaultLocation(std::string const &path) {
    LocationConfig l;
    l.redirect_code = 0;
    l.allow_get = true;
    l.allow_post = false;
    l.allow_delete = false;
    l.autoindex = false;
    l.has_redirect = false;
    l.upload_enabled = false;
    l.path = path;
    l.root = "";
    l.index = "";
    l.upload_store = "";
    l.redirect_target = "";
    return l;
}

static void assignCgiMapping(LocationConfig &loc,
                             std::vector<std::string> const &paths,
                             std::vector<std::string> const &exts,
                             Token const &whereTok) {
    if (paths.empty())
        throw parseError(whereTok, "cgi_ext requires cgi_path first");
    if (exts.empty())
        throw parseError(whereTok, "cgi_ext requires at least one extension");

    if (paths.size() == 1) {
        for (size_t i = 0; i < exts.size(); i++)
            loc.cgi[exts[i]] = paths[0];
        return;
    }
    if (paths.size() == exts.size()) {
        for (size_t i = 0; i < exts.size(); i++)
            loc.cgi[exts[i]] = paths[i];
        return;
    }
    throw parseError(whereTok, "cgi_path count must be 1 or match cgi_ext count");
}

static LocationConfig parseLocation(Parser &p) {
    p.expectWord("location");
    std::string path = p.expectValue("location path");
    p.expect(LBrace, "expected '{' after location path");

    LocationConfig loc = defaultLocation(path);

    std::vector<std::string> cgiPaths;
    std::vector<std::string> pendingExts;
    bool sawCgiPath = false;
    bool sawCgiExt = false;

    while (!p.at(RBrace)) {
        if (p.at(End))
            throw parseError(p.peek(), "unexpected end inside location block");

        if (!isValueToken(p.peek()))
            throw parseError(p.peek(), "expected directive name inside location");

        std::string name = p.peek().value;

        if (p.atWord("allow_methods")) {
            p.advance();
            loc.allow_get = false;
            loc.allow_post = false;
            loc.allow_delete = false;

            while (!p.at(Semicolon)) {
                if (p.at(End)) throw parseError(p.peek(), "unexpected end in allow_methods");
                std::string m = p.expectValue("allow_methods");
                if (m == "GET") loc.allow_get = true;
                else if (m == "POST") loc.allow_post = true;
                else if (m == "DELETE") loc.allow_delete = true;
                else throw parseError(p.peek(0), "unsupported method: '" + m + "'");
            }
            p.expect(Semicolon, "expected ';' after allow_methods");
            continue;
        }

        if (p.atWord("autoindex")) {
            p.advance();
            std::string v = p.expectValue("autoindex");
            if (v == "on") loc.autoindex = true;
            else if (v == "off") loc.autoindex = false;
            else throw parseError(p.peek(0), "autoindex must be 'on' or 'off'");
            p.expect(Semicolon, "expected ';' after autoindex");
            continue;
        }

        if (p.atWord("root")) {
            p.advance();
            loc.root = p.expectValue("root");
            p.expect(Semicolon, "expected ';' after root");
            continue;
        }

        if (p.atWord("index")) {
            p.advance();
            loc.index = p.expectValue("index");
            p.expect(Semicolon, "expected ';' after index");
            continue;
        }

        if (p.atWord("upload")) {
            p.advance();
            std::string v = p.expectValue("upload");
            if (v == "on") loc.upload_enabled = true;
            else if (v == "off") loc.upload_enabled = false;
            else throw parseError(p.peek(0), "upload must be 'on' or 'off'");
            p.expect(Semicolon, "expected ';' after upload");
            continue;
        }

        if (p.atWord("upload_store")) {
            p.advance();
            loc.upload_store = p.expectValue("upload_store");
            p.expect(Semicolon, "expected ';' after upload_store");
            continue;
        }

        if (p.atWord("return")) {
            p.advance();
            Token const whereTok = p.peek();
            std::string a1 = p.expectValue("return");
            if (p.at(Semicolon)) {
                loc.redirect_code = 301;
                loc.redirect_target = a1;
                loc.has_redirect = true;
                p.expect(Semicolon, "expected ';' after return");
                continue;
            }
            // return <code> <target>;
            Token codeTok;
            codeTok.type = Number;
            codeTok.value = a1;
            codeTok.line = whereTok.line;
            codeTok.col = whereTok.col;

            unsigned long code = parseUL(codeTok, "return code");
            std::string target = p.expectValue("return target");
            p.expect(Semicolon, "expected ';' after return");

            loc.redirect_code = (int)code;
            loc.redirect_target = target;
            loc.has_redirect = true;
            continue;
        }

        if (p.atWord("cgi_path")) {
            p.advance();
            cgiPaths.clear();
            sawCgiPath = true;

            while (!p.at(Semicolon)) {
                if (p.at(End)) throw parseError(p.peek(), "unexpected end in cgi_path");
                cgiPaths.push_back(p.expectValue("cgi_path"));
            }
            p.expect(Semicolon, "expected ';' after cgi_path");

            if (sawCgiExt) {
                assignCgiMapping(loc, cgiPaths, pendingExts, p.peek());
                pendingExts.clear();
                sawCgiExt = false;
            }
            continue;
        }

        if (p.atWord("cgi_ext")) {
            p.advance();
            pendingExts.clear();
            sawCgiExt = true;
            Token const whereTok = p.peek();

            while (!p.at(Semicolon)) {
                if (p.at(End)) throw parseError(p.peek(), "unexpected end in cgi_ext");
                std::string ext = p.expectValue("cgi_ext");
                if (ext.empty() || ext[0] != '.')
                    throw parseError(whereTok, "cgi_ext entries must start with '.'");
                pendingExts.push_back(ext);
            }
            p.expect(Semicolon, "expected ';' after cgi_ext");

            if (sawCgiPath) {
                assignCgiMapping(loc, cgiPaths, pendingExts, whereTok);
                pendingExts.clear();
                sawCgiExt = false;
            }
            continue;
        }

        // unknown directive in location: skip it (or block)
        p.skipUnknownStatement();
    }

    p.expect(RBrace, "expected '}' to close location block");

    if (sawCgiExt)
        throw parseError(p.peek(), "cgi_ext specified without cgi_path");

    return loc;
}

static void parseListen(Parser &p, ServerConfig &srv, bool &sawListen) {
    p.expectWord("listen");

    Token const firstTok = p.peek();
    std::string a1 = p.expectValue("listen");

    std::string host;
    std::string portStr;

    size_t colon = a1.find(':');
    if (colon != std::string::npos) {
        host = a1.substr(0, colon);
        portStr = a1.substr(colon + 1);
    } else if (p.at(Semicolon)) {
        portStr = a1;
    } else {
        std::string a2 = p.expectValue("listen");
        host = a1;
        portStr = a2;
    }

    p.expect(Semicolon, "expected ';' after listen");

    if (sawListen)
        throw parseError(firstTok, "duplicate listen in same server block");
    sawListen = true;

    Token portTok;
    portTok.type = Number;
    portTok.value = portStr;
    portTok.line = firstTok.line;
    portTok.col = firstTok.col;

    unsigned long port = parseUL(portTok, "listen port");
    if (port == 0 || port > 65535)
        throw parseError(firstTok, "listen port out of range");

    srv.port = (int)port;
    if (!host.empty())
        srv.host = host;
}

static ServerConfig parseServer(Parser &p) {
    p.expectWord("server");
    p.expect(LBrace, "expected '{' after server");

    ServerConfig srv = defaultServer();
    bool sawListen = false;

    while (!p.at(RBrace)) {
        if (p.at(End))
            throw parseError(p.peek(), "unexpected end inside server block");

        if (!isValueToken(p.peek()))
            throw parseError(p.peek(), "expected directive name inside server");

        if (p.atWord("listen")) {
            parseListen(p, srv, sawListen);
            continue;
        }

        if (p.atWord("host")) {
            p.advance();
            srv.host = p.expectValue("host");
            p.expect(Semicolon, "expected ';' after host");
            continue;
        }

        if (p.atWord("root")) {
            p.advance();
            srv.root = p.expectValue("root");
            p.expect(Semicolon, "expected ';' after root");
            continue;
        }

        if (p.atWord("index")) {
            p.advance();
            srv.index = p.expectValue("index");
            p.expect(Semicolon, "expected ';' after index");
            continue;
        }

        if (p.atWord("client_max_body_size")) {
            p.advance();
            Token const nTok = p.peek();
            unsigned long v = parseUL(nTok, "client_max_body_size");
            p.advance();
            p.expect(Semicolon, "expected ';' after client_max_body_size");
            srv.client_max_body_size = (size_t)v;
            continue;
        }

        if (p.atWord("error_page")) {
            p.advance();
            Token const codeTok = p.peek();
            unsigned long code = parseUL(codeTok, "error_page code");
            p.advance();
            std::string path = p.expectValue("error_page path");
            p.expect(Semicolon, "expected ';' after error_page");
            srv.error_pages[(int)code] = path;
            continue;
        }

        if (p.atWord("location")) {
            srv.locations.push_back(parseLocation(p));
            continue;
        }

        // accept but ignore server_name (common in configs)
        if (p.atWord("server_name")) {
            p.skipUnknownStatement();
            continue;
        }

        // unknown directive/block at server scope: skip
        p.skipUnknownStatement();
    }

    p.expect(RBrace, "expected '}' to close server block");

    if (!sawListen)
        throw parseError(p.peek(), "server missing listen");

    return srv;
}

std::string readFile(std::string const &path) {
    std::ifstream infile(path.c_str());
    if (!infile.is_open())
        throw std::runtime_error("Could not open config file");
    if (path.size() < 5 || path.substr(path.size() - 5) != ".conf")
        throw std::runtime_error("Config file must end with .conf");

    std::string content;
    std::string line;
    while (std::getline(infile, line))
        content += line + "\n";
    return content;
}

Config parseConfig(std::vector<Token> const &tokens) {
    Parser p(tokens);
    Config cfg;

    while (!p.at(End)) {
        if (p.atWord("server"))
            cfg.servers.push_back(parseServer(p));
        else
            throw parseError(p.peek(), "expected 'server' block");
    }

    if (cfg.servers.empty())
        throw std::runtime_error("No servers found in config");
    return cfg;
}

int main(int argc, char **argv) {
    try {
        if (argc != 2)
            throw std::runtime_error("Usage: ./a.out <config.conf>");

        std::string text = readFile(argv[1]);
        std::vector<Token> tokens = tokenize(text);
        Config cfg = parseConfig(tokens);

        std::cout << "Parsed servers: " << cfg.servers.size() << std::endl;
    } catch (std::exception &e) {
        std::cout << "Error: " << e.what() << std::endl;
        return 1;
    }
    return 0;
}